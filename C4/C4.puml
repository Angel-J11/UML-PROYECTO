@startuml

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C4 - Diagrama de Contenedores - RutaFlex
Person(usuario, "Usuario", "Pasajero o Conductor")

System_Boundary(system, "RutaFlex") {

Container(web, "Landing Page", "React / HTML", "Página informativa y acceso a descarga")

Container(app, "Mobile App", "Flutter", "Aplicación móvil principal")

Container(api, "Backend API", "Node.js / Spring Boot", "Gestiona lógica de negocio")

ContainerDb(db, "MySQL Database", "MySQL", "Almacena usuarios, viajes y mensajes")

Container(notification, "Notification Service", "Firebase", "Gestión de notificaciones push")

}

System_Ext(googlemaps, "Google Maps API", "Servicios de mapas y geolocalización")

System_Ext(emailservice, "Servicio de Correos", "Verificación institucional")


Rel(usuario, web, "Consulta información")
Rel(usuario, app, "Usa")

Rel(web, app, "Redirecciona descarga")

Rel(app, api, "HTTPS / JSON")
Rel(api, db, "CRUD SQL")

Rel(api, notification, "Envía eventos")
Rel(notification, app, "Push notifications")

Rel(api, googlemaps, "Solicita rutas")
Rel(api, emailservice, "Verifica correos")

@enduml
