@startuml ""
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam Arrow {
  Color #7A1631
}

actor "Estudiante" as Student

rectangle "Valorar Experiencia" {

    usecase "Seleccionar\nViaje" as UC1
    usecase "Calificar\nUsuario" as UC2
    usecase "Registrar\nComentario" as UC3

}

Student --> UC1

UC1 --> UC2
UC2 --> UC3

@enduml