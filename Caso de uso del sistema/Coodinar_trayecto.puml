@startuml ""
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam Arrow {
  Color #7A1631
}

actor "Estudiante\nPasajero" as Passenger

rectangle "Coordinar Trayecto" {

    actor "Estudiante\nConductor" as Driver

    usecase "Enviar\nMensaje" as UC1
    usecase "Recibir\nMensaje" as UC2
    usecase "Confirmar\nCoordinación" as UC3

}

Passenger --> UC1

Driver <-- UC2

UC1 --> UC2
UC2 --> UC3

@enduml