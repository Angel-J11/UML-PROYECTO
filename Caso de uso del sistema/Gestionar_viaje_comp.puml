@startuml ""
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam Arrow {
  Color #7A1631
}

actor "Estudiante\nConductor" as Driver

rectangle "Gestionar Viajes Compartidos" {

    usecase "Visualizar\nViajes" as UC1
    usecase "Modificar\nViaje" as UC2
    usecase "Cancelar\nViaje" as UC3

}

Driver --> UC1

UC1 --> UC2
UC1 --> UC3

@enduml