@startuml ""
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam Arrow {
  Color #7A1631
}

actor "Estudiante\nConductor" as Driver

rectangle "Publicar Ruta" {

    actor "Servicio de\nMapas" as Maps

    usecase "Ingresar\nRuta" as UC1
    usecase "Validar\nUbicación" as UC2
    usecase "Registrar\nRuta" as UC3

}

Driver --> UC1
Maps --> UC2

UC1 --> UC2
UC2 --> UC3

@enduml