@startuml ""
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam Arrow {
  Color #7A1631
}

actor "Estudiante" as Student

rectangle "Consultar Historial y Ahorro" {

    usecase "Consultar\nHistorial" as UC1
    usecase "Visualizar\nAhorro" as UC2
    usecase "Consultar\nImpacto Ambiental" as UC3

}

Student --> UC1

UC1 --> UC2
UC2 --> UC3

@enduml