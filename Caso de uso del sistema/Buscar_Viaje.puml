@startuml ""
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}

skinparam Arrow {
  Color #7A1631
}

actor "Estudiante\nPasajero" as Passenger

rectangle "Buscar Viaje" {

    actor "Servicio de\nMapas" as Maps

    usecase "Ingresar\nDestino" as UC1
    usecase "Buscar\nViajes" as UC2
    usecase "Visualizar\nResultados" as UC3

}

Passenger --> UC1
Maps --> UC2

UC1 --> UC2
UC2 --> UC3

@enduml