@startuml
skinparam classAttributeIconSize 0

title Bounded Context - Comunicación

class Chat {
  +id: idChat
  +estado: String
  +fechaCreacion: DateTime
}

class Mensaje {
  +id: idMensaje
  +contenido: String
  +fechaEnvio: DateTime
  +leido: boolean
}

class Notificacion {
  +id: idNotificacion
  +tipo: String
  +contenido: String
  +fechaEnvio: DateTime
}

class UbicacionCompartida {
  +id: idUbicacion
  +latitud: Double
  +longitud: Double
  +fechaActualizacion: DateTime
}

Chat "1" o-- "0..*" Mensaje
Chat "1" o-- "0..*" Notificacion
Chat "1" o-- "0..*" UbicacionCompartida
Mensaje --> Chat
Notificacion --> Chat
UbicacionCompartida --> Chat
@enduml
